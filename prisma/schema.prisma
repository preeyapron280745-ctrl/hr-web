  emName1                  String?
  emRelation1              String?
  emPhone1                 String?
  emTitle2                 String?
  emName2                  String?
  emRelation2              String?
  emPhone2                 String?
  allowPrevEmployerContact String?
  allowPrevEmployerReason  String?
  nonRelRelation           String?
