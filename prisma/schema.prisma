  availableStartDate       DateTime?            @db.Date
  lastYearExperience       String?
  internStartDate          DateTime?            @db.Date
  internEndDate            DateTime?            @db.Date
  internDepartment         String?
  photoUrl                 String?
  resumeUrl                String?
  titleTh                  String?
  firstNameTh              String?
  lastNameTh               String?
  titleEn                  String?
  firstNameEn              String?
  lastNameEn               String?
  nicknameTh               String?
  nicknameEn               String?
  phone                    String?
  dateOfBirth              DateTime?            @db.Date
  age                      Int?
  birthProvince            String?
  nationality              String?
  ethnicity                String?
  religion                 String?
  height                   Float?
  weight                   Float?
  email                    String?
  lineId                   String?
  currentAddress           String?
  permanentAddress         String?
  socialSecurityStatus     String?
  hospitalWithSS           String?
  hospitalWithSSOther      String?
  hospitalNoSS             String?
  hospitalNoSSOther        String?
  maritalStatus            String?
  spouseTitle              String?
  spouseName               String?
  spouseOccupation         String?
  spouseWorkplace          String?
  spousePhone              String?
  numChildren              Int?
  fatherTitle              String?
  fatherName               String?
  fatherStatus             String?
  fatherAge                Int?
  fatherOccupation         String?
  fatherPhone              String?
  motherTitle              String?
  motherName               String?
  motherStatus             String?
  motherAge                Int?
  motherOccupation         String?
  motherPhone              String?
  siblings                 Int?
  childOrder               Int?
  educationLevels          String[]
  educationData            Json?
  internStudyYear          String?
  internGpa                Float?
  internInstitution        String?
  internFaculty            String?
  internMajor              String?
  advisorTitle             String?
  advisorName              String?
  advisorPhone             String?
  advisorEmail             String?
  computerSkills           String[]
  excelSkills              String[]
  excelSkillsOther         String?
  wordSkills               String[]
  wordSkillsOther          String?
  powerpointSkills         String[]
  powerpointSkillsOther    String?
  photoshopSkills          String[]
  photoshopSkillsOther     String?
  otherSkills              String?
  interestedWork           String?
  travelMode               String?
  shuttleRoute             String?
  canDriveCar              String?
  carLicenseNumber         String?
  hasCar                   String?
  carPlate                 String?
  canDriveMotorcycle       String?
  motorcycleLicenseNumber  String?
  hasMotorcycle            String?
  motorcyclePlate          String?
  firedForMisconduct       String?
  firedReason              String?
  smoke                    String?
  smokeReason              String?
  smokeFrequency           String?
  alcohol                  String?
  alcoholReason            String?
  alcoholFrequency         String?
  drugs                    String?
  drugsReason              String?
  seriousInjury            String?
