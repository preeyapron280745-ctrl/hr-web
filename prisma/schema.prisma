  updatedAt                DateTime             @updatedAt

  trainings               TrainingItem[]
  workExperiences         WorkExperienceItem[]
  languages               LanguageItem[]
  interviewEvaluations    InterviewEvaluation[]
  probationEvaluations    ProbationEvaluation[]
}

model InterviewEvaluation {
  id             String          @id @default(cuid())
  form           ApplicationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId         String
  evaluatorId    String?
  evaluationDate DateTime        @db.Date
  round          Int             @default(1)
  personality    Int?
  communication  Int?
  knowledge      Int?
  experience     Int?
  attitude       Int?
  overallScore   Int?
  recommendation String?
  strengths      String?
  weaknesses     String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ProbationEvaluation {
  id              String          @id @default(cuid())
  form            ApplicationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId          String
  evaluatorId     String?
  evaluationDate  DateTime        @db.Date
  round           Int             @default(1)
  workQuality     Int?
  discipline      Int?
  teamwork        Int?
  responsibility  Int?
  learningAbility Int?
  overallScore    Int?
  result          String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model TrainingItem {
  id          String          @id @default(cuid())
  form        ApplicationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId      String
  courseName  String
  institution String?
  year        Int?
  duration    String?
  certificate Boolean         @default(false)
}

model WorkExperienceItem {
  id               String          @id @default(cuid())
  form             ApplicationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId           String
  company          String
  position         String
  startDate        DateTime?       @db.Date
  endDate          DateTime?       @db.Date
  salary           Float?
  reasonForLeaving String?
  responsibilities String?
}

model LanguageItem {
  id        String          @id @default(cuid())
  form      ApplicationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId    String
  language  String
  speaking  String?
  reading   String?
  writing   String?
  listening String?
}
